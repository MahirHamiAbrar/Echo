{
  "name": "echo",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/client"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev-hot": "bun run --parallel --filter '*' dev hot",
    "dev-watch": "bun run --parallel --filter '*' dev watch",
    "build": "bun run --parallel --filter '*' build",
    "prod": "bun run build && bun run --parallel --filter '*' prod",
    "start": "bun run prod",
    "root-clean": "rm -rf node_modules bun.lockb",
    "clean": "bun run root-clean && bun run --parallel --filter '*' clean"
  }
}
